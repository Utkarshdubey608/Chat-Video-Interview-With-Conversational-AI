# ─── Server-only secrets (NEVER exposed to the client bundle) ──────────────
# Google Gemini API key. Used only by the Express server for résumé-based
# question generation and answer scoring. Leave blank to run with the
# heuristic fallback (no AI).
GEMINI_API_KEY=

# Gemini model to use (optional).
GEMINI_MODEL=gemini-2.5-flash

# Port the API server listens on (optional; Vite proxies /api here).
PORT=8787

# ─── Production / Google Cloud (see docs/DEPLOYMENT.md) — server-only ──────
# Prefer Vertex AI (service-account/IAM auth) over an API key on production.
# When USE_VERTEX=true the server should auth via Application Default
# Credentials (the Cloud Run service account) — no key string on any device.
USE_VERTEX=false
GOOGLE_CLOUD_PROJECT=
VERTEX_LOCATION=us-central1

# Client → API base URL for the native (Capacitor/Play Store) build ONLY.
# In web/dev the Vite proxy handles /api, so leave this blank there.
# This is a public base URL, NOT a secret (the key stays on the server).
VITE_API_BASE=
