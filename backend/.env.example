# Copy to .env and fill in. Safe dev defaults everywhere except Gmail creds.

# --- App ---
APP_NAME=TalbotIQ Mailer
CORS_ORIGINS=*

# --- Auth ---
# Shared secret the Flutter app sends as X-API-Key. Empty = auth DISABLED (dev).
API_KEY=

# --- Database (queue + saved templates) ---
DATABASE_URL=sqlite:///./mailer.db

# --- Delivery: keep DRY_RUN=true to log instead of send (no creds needed) ---
DRY_RUN=true

# --- Gmail API (OAuth refresh token) ---
# One-time setup (see README): create an OAuth Desktop client, authorise the
# gmail.send scope, and capture a refresh token.
EMAIL_USER=your@gmail.com
GMAIL_CLIENT_ID=xxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=xxxxx
GMAIL_REFRESH_TOKEN=xxxxx

# --- Queue / workers ---
WORKER_CONCURRENCY=4
JOB_MAX_ATTEMPTS=3
RETRY_BACKOFF_SECONDS=10
POLL_INTERVAL_SECONDS=2
